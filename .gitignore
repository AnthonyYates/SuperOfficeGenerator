## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio cache/options directory
.vs/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bin/
obj/
out/

# .NET / NuGet
*.nupkg
*.snupkg
packages/
!**/packages/build/
*.nuget.props
*.nuget.targets

# Logs
*.log

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# ReSharper
_ReSharper*/
*.ReSharper

# Rider
.idea/
*.sln.iml

# DotCover
*.dotCover

# JetBrains Rider generated
*.DotSettings.user

# Publish output
publish/

# Azure Functions local settings
local.settings.json
