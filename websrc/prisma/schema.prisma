generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Template {
  id            String   @id
  name          String
  description   String
  mode          String   @default("massops")
  entities      String   // JSON: EntityDefinition[]
  schemaVersion Int      @default(1)
  createdBy     String
  updatedAt     DateTime

  jobs          Job[]
}

model Job {
  id              String    @id
  templateId      String
  locales         String    // JSON: string[]
  requestedCounts String    // JSON: Record<string, number>
  apiMode         String
  status          String
  createdBy       String
  createdAt       DateTime
  completedAt     DateTime?
  metrics         String    // JSON: JobMetricSummary
  items           String    // JSON: JobItemLog[]
  phases          String?   // JSON: Record<string, JobPhaseResult>

  template        Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model DatabaseModel {
  id           String   @id @default(cuid())
  version      String   @unique // NetServerVersion e.g. "11.12.760.0"
  releaseDate  DateTime // NetServerDate e.g. "2026-03-27"
  downloadedAt DateTime @default(now())
  tables       String   // JSON: DbModelTable[]
}
